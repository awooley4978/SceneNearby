{
  "expo": {
    "name": "Scene Nearby",
    "slug": "scene-nearby",
    "version": "1.0.0",
    "scheme": "scenenearby",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#1a1a2e",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cairn.scenenearby",
      "buildNumber": "1.0.0",
      "config": {
        "googleMapsApiKey": "AIzaSyBLUZWpL5Z0S2_G_tcddtInru-KFeMivLs"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Scene Nearby uses your location to show you nearby filming locations.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Scene Nearby uses your location to alert you when you're near a filming location.",
        "LSApplicationQueriesSchemes": [
          "waze",
          "maps",
          "comgooglemaps"
        ]
      }
    },
    "android": {
      "package": "com.cairn.scenenearby",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Scene Nearby uses your location to alert you when you're near a filming location.",
          "locationWhenInUsePermission": "Scene Nearby uses your location to show you nearby filming locations."
        }
      ],
      "expo-dev-client"
    ],
    "extra": {
      "eas": {
        "projectId": "0e688584-d597-4110-bef7-13784736463e"
      }
    }
  }
}